{
  "expo": {
    "name": "Bridge Verified",
    "slug": "bridge-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Bridgeicon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1F35"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bridgetx.app",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": "./assets/Bridgeicon.png"
    },
    "android": {
      "package": "com.bridgetx.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0F1F35",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ec867eed-2166-468d-b6bc-7bbf943560a1"
      }
    },
    "owner": "ckuskie",
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/Bridgeicon.png",
          "color": "#E07B2A",
          "androidMode": "default",
          "androidCollapsedTitle": "Bridge Storm Alert"
        }
      ],
      "@sentry/react-native",
      "@sentry/react-native"
    ]
  }
}